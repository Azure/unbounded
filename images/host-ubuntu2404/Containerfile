# ── Build the unbounded-agent binary ────────────────────────────────
FROM --platform=$BUILDPLATFORM docker.io/library/golang:1.26 AS gobuilder

ARG TARGETARCH
ARG VERSION=dev

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build \
    -ldflags "-s -w \
      -X github.com/Azure/unbounded-kube/internal/version.Version=${VERSION} \
      -X github.com/Azure/unbounded-kube/internal/version.GitCommit=$(git rev-parse --short HEAD 2>/dev/null || echo unknown)" \
    -o /unbounded-agent ./cmd/agent

# ── Assemble host image artifacts ───────────────────────────────────
FROM docker.io/library/debian:bookworm-slim AS build

ARG TARGETARCH

RUN apt-get update && apt-get install -y --no-install-recommends \
        cpio curl ca-certificates qemu-utils libguestfs-tools linux-image-${TARGETARCH} \
    && rm -rf /var/lib/apt/lists/*

# ── Download netboot artifacts ──────────────────────────────────────
# Ubuntu netboot layout differs by architecture:
#   amd64: individual files at releases.ubuntu.com
#   arm64: tarball at cdimage.ubuntu.com (individual URLs are unavailable)
# File names follow UEFI convention: shimx64/grubx64 (amd64), shimaa64/grubaa64 (arm64).
# metalman looks up the boot filename from metadata.yaml (dhcpBootImageName).
RUN mkdir -p /artifacts && \
    if [ "${TARGETARCH}" = "amd64" ]; then \
        NETBOOT_BASE="https://releases.ubuntu.com/24.04.2/netboot/amd64"; \
        curl -fSL -o /artifacts/shimx64.efi  "${NETBOOT_BASE}/bootx64.efi" && \
        curl -fSL -o /artifacts/grubx64.efi  "${NETBOOT_BASE}/grubx64.efi" && \
        curl -fSL -o /artifacts/vmlinuz      "${NETBOOT_BASE}/linux"       && \
        curl -fSL -o /artifacts/initrd       "${NETBOOT_BASE}/initrd"; \
    elif [ "${TARGETARCH}" = "arm64" ]; then \
        NETBOOT_URL="https://cdimage.ubuntu.com/releases/noble/release/ubuntu-24.04.4-netboot-arm64.tar.gz"; \
        curl -fSL -o /tmp/netboot.tar.gz "${NETBOOT_URL}" && \
        tar -xzf /tmp/netboot.tar.gz -C /tmp && \
        cp /tmp/arm64/bootaa64.efi   /artifacts/shimaa64.efi && \
        cp /tmp/arm64/grubaa64.efi   /artifacts/grubaa64.efi && \
        cp /tmp/arm64/linux           /artifacts/vmlinuz && \
        cp /tmp/arm64/initrd          /artifacts/initrd && \
        rm -rf /tmp/netboot.tar.gz /tmp/arm64; \
    else \
        echo "Unsupported architecture: ${TARGETARCH}" >&2; exit 1; \
    fi

# ── Build init.cpio overlay ─────────────────────────────────────────
COPY images/host-ubuntu2404/assets/init /tmp/initrd-root/init
RUN chmod 755 /tmp/initrd-root/init && \
    cd /tmp/initrd-root && \
    find . -print0 | cpio --create --format=newc --quiet --null > /artifacts/init.cpio

# ── Assemble /disk directory ────────────────────────────────────────
RUN mkdir -p /disk/grub /disk/cloud-init

# Binary boot artifacts (architecture-specific EFI names for metalman TFTP).
RUN cp /artifacts/vmlinuz /artifacts/initrd /artifacts/init.cpio /disk/ && \
    if [ "${TARGETARCH}" = "amd64" ]; then \
        cp /artifacts/shimx64.efi /artifacts/grubx64.efi /disk/; \
    elif [ "${TARGETARCH}" = "arm64" ]; then \
        cp /artifacts/shimaa64.efi /artifacts/grubaa64.efi /disk/; \
    fi

# Templates and static configs from assets/.
COPY images/host-ubuntu2404/assets/grub.cfg.tmpl               /disk/grub/grub.cfg.tmpl
COPY images/host-ubuntu2404/assets/meta-data.tmpl              /disk/cloud-init/meta-data.tmpl
COPY images/host-ubuntu2404/assets/vendor-data.tmpl            /disk/cloud-init/vendor-data.tmpl

# Generate metadata.yaml with the correct boot image name for this architecture.
# metalman reads dhcpBootImageName to tell PXE clients which file to request via TFTP.
RUN if [ "${TARGETARCH}" = "amd64" ]; then \
        echo "dhcpBootImageName: shimx64.efi" > /disk/metadata.yaml; \
    elif [ "${TARGETARCH}" = "arm64" ]; then \
        echo "dhcpBootImageName: shimaa64.efi" > /disk/metadata.yaml; \
    fi

# User-data is now a Go template rendered per-node by metalman.
# The unbounded-agent handles kubelet/containerd/TPM attestation
# internally, so no attest script injection or kubelet configs are needed.
COPY images/host-ubuntu2404/assets/user-data.tmpl             /disk/cloud-init/user-data.tmpl

# ── Download and convert Ubuntu cloud image to raw+gzip ─────────────
# Cloud image URL is parameterized by architecture.
ARG UBUNTU_CLOUDIMG_URL=https://cloud-images.ubuntu.com/releases/noble/release/ubuntu-24.04-server-cloudimg-${TARGETARCH}.img

# Copy the agent binary from the builder so we can inject it into the
# cloud image before gzipping.  It is also placed at /disk/unbounded-agent
# (below) so metalman can serve it to other provisioning paths.
COPY --from=gobuilder /unbounded-agent /tmp/unbounded-agent

RUN curl -fSL -o /tmp/cloudimg.qcow2 "${UBUNTU_CLOUDIMG_URL}" && \
    qemu-img convert -f qcow2 -O raw /tmp/cloudimg.qcow2 /tmp/disk.img && \
    rm /tmp/cloudimg.qcow2 && \
    LIBGUESTFS_BACKEND=direct virt-customize -a /tmp/disk.img \
        --mkdir /usr/local/bin \
        --copy-in /tmp/unbounded-agent:/usr/local/bin \
        --chmod 0755:/usr/local/bin/unbounded-agent && \
    gzip -1 /tmp/disk.img && \
    mv /tmp/disk.img.gz /disk/disk.img.gz

# ── Agent binary built from source ──────────────────────────────────
COPY --from=gobuilder /unbounded-agent /disk/unbounded-agent

FROM scratch
COPY --from=build /disk /disk
