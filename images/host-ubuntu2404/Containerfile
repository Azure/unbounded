# ── Build the unbounded-agent binary ────────────────────────────────
FROM docker.io/library/golang:1.26 AS gobuilder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /unbounded-agent ./cmd/agent

# ── Assemble host image artifacts ───────────────────────────────────
FROM docker.io/library/debian:bookworm-slim AS build

RUN apt-get update && apt-get install -y --no-install-recommends \
        cpio curl ca-certificates qemu-utils libguestfs-tools linux-image-amd64 \
    && rm -rf /var/lib/apt/lists/*

# ── Download netboot artifacts ──────────────────────────────────────
ARG UBUNTU_NETBOOT_BASE=https://releases.ubuntu.com/24.04.2/netboot/amd64

RUN mkdir -p /artifacts && \
    curl -fSL -o /artifacts/shimx64.efi "${UBUNTU_NETBOOT_BASE}/bootx64.efi" && \
    curl -fSL -o /artifacts/grubx64.efi "${UBUNTU_NETBOOT_BASE}/grubx64.efi" && \
    curl -fSL -o /artifacts/vmlinuz     "${UBUNTU_NETBOOT_BASE}/linux"       && \
    curl -fSL -o /artifacts/initrd      "${UBUNTU_NETBOOT_BASE}/initrd"

# ── Build init.cpio overlay ─────────────────────────────────────────
COPY images/host-ubuntu2404/assets/init /tmp/initrd-root/init
RUN chmod 755 /tmp/initrd-root/init && \
    cd /tmp/initrd-root && \
    find . -print0 | cpio --create --format=newc --quiet --null > /artifacts/init.cpio

# ── Assemble /disk directory ────────────────────────────────────────
RUN mkdir -p /disk/grub /disk/cloud-init

# Binary boot artifacts.
RUN cp /artifacts/shimx64.efi /artifacts/grubx64.efi \
       /artifacts/vmlinuz     /artifacts/initrd       \
       /artifacts/init.cpio   /disk/

# Templates and static configs from assets/.
COPY images/host-ubuntu2404/assets/grub.cfg.tmpl               /disk/grub/grub.cfg.tmpl
COPY images/host-ubuntu2404/assets/meta-data.tmpl              /disk/cloud-init/meta-data.tmpl
COPY images/host-ubuntu2404/assets/vendor-data.tmpl            /disk/cloud-init/vendor-data.tmpl
COPY images/host-ubuntu2404/assets/metadata.yaml              /disk/metadata.yaml

# User-data is now a Go template rendered per-node by metalman.
# The unbounded-agent handles kubelet/containerd/TPM attestation
# internally, so no attest script injection or kubelet configs are needed.
COPY images/host-ubuntu2404/assets/user-data.tmpl             /disk/cloud-init/user-data.tmpl

# ── Download and convert Ubuntu cloud image to raw+gzip ─────────────
ARG UBUNTU_CLOUDIMG_URL=https://cloud-images.ubuntu.com/releases/noble/release/ubuntu-24.04-server-cloudimg-amd64.img

# Copy the agent binary from the builder so we can inject it into the
# cloud image before gzipping.  It is also placed at /disk/unbounded-agent
# (below) so metalman can serve it to other provisioning paths.
COPY --from=gobuilder /unbounded-agent /tmp/unbounded-agent

RUN curl -fSL -o /tmp/cloudimg.qcow2 "${UBUNTU_CLOUDIMG_URL}" && \
    qemu-img convert -f qcow2 -O raw /tmp/cloudimg.qcow2 /tmp/disk.img && \
    rm /tmp/cloudimg.qcow2 && \
    LIBGUESTFS_BACKEND=direct virt-customize -a /tmp/disk.img \
        --mkdir /usr/local/bin \
        --copy-in /tmp/unbounded-agent:/usr/local/bin \
        --chmod 0755:/usr/local/bin/unbounded-agent && \
    gzip -1 /tmp/disk.img && \
    mv /tmp/disk.img.gz /disk/disk.img.gz

# ── Agent binary built from source ──────────────────────────────────
COPY --from=gobuilder /unbounded-agent /disk/unbounded-agent

FROM scratch
COPY --from=build /disk /disk
