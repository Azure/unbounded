# Build stage
# Pin the builder to BUILDPLATFORM so the Go toolchain runs natively on the
# host even when targeting a foreign TARGETPLATFORM. Without this, buildkit
# would emulate the entire builder under QEMU when producing arm64 images on
# an amd64 runner, which makes "go build" painfully slow.
FROM --platform=$BUILDPLATFORM docker.io/library/golang:1.26.2-trixie AS builder

# Install build dependencies. The base image already provides the Go
# toolchain at /usr/local/go/bin, so we don't install the apt golang package.
RUN apt-get update && apt-get install -y \
    build-essential \
    make \
    gcc \
    git \
    ca-certificates \
    && apt-get clean

# Set up Go environment.
# CGO is disabled because cmd/machina has no cgo imports; this also keeps
# cross-compilation simple (no cross C toolchain required).
ENV CGO_ENABLED=0
ENV GOPATH=/go
ENV GOTOOLCHAIN=auto
ENV PATH=$PATH:/go/bin

# Set working directory
WORKDIR /src

# Copy go mod files first for better caching
COPY go.mod go.sum ./
RUN go mod download

# Copy the rest of the source code
COPY ../../ .

# TARGETOS/TARGETARCH are populated by buildkit from the requested
# --platform; threading them into go via GOOS/GOARCH lets the builder run
# natively on the host while still producing target-arch binaries.
ARG TARGETOS
ARG TARGETARCH

# VERSION/GIT_COMMIT/BUILD_TIME are passed in to inject version metadata via ldflags.
# Empty defaults let the Makefile fall back to its own git/date detection when callers
# don't supply explicit values; ${VAR:+...} forwards only when the caller set them.
ARG VERSION=dev
ARG GIT_COMMIT=
ARG BUILD_TIME=
RUN GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    make machina-build VERSION=${VERSION} ${GIT_COMMIT:+GIT_COMMIT=${GIT_COMMIT}} ${BUILD_TIME:+BUILD_TIME=${BUILD_TIME}}

# Runtime stage
FROM ubuntu:noble

# Install runtime dependencies
RUN apt-get update && apt-get upgrade -y && apt-get install -y --no-install-recommends \
    ca-certificates \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Create unbounded directory
RUN mkdir -p /unbounded/bin

# Copy the built binaries from the builder stage
COPY --from=builder /src/bin/machina /unbounded/bin/machina

# Add unbounded bin to PATH
ENV PATH="/unbounded/bin:${PATH}"

# Set working directory
WORKDIR /unbounded

# Default entrypoint
ENTRYPOINT ["/unbounded/bin/machina"]
