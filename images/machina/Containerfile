# Build stage
FROM mcr.microsoft.com/azurelinux/base/core:3.0@sha256:35149ae8dd179684f969944f54a337c665a64e702486154eb44253fb39c2505b AS builder

# Install build dependencies
RUN tdnf install -y \
    build-essential \
    golang \
    make \
    gcc \
    git \
    ca-certificates \
    && tdnf clean all

# Set up Go environment
ENV CGO_ENABLED=1
ENV GOPATH=/go
ENV GOTOOLCHAIN=auto
# Azure Linux 3.0's Go package restricts GOTOOLCHAIN to "local" by default.
# Allow "auto" so that go install can download the required toolchain.
ENV MS_GOTOOLCHAIN_ALLOW_NON_LOCAL=1
ENV PATH=$PATH:/go/bin

# Install gofumpt and golangci-lint for the build
RUN go install mvdan.cc/gofumpt@latest && \
    go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest

# Set working directory
WORKDIR /src

# Copy go mod files first for better caching
COPY go.mod go.sum ./
RUN go mod download

# Copy the rest of the source code
COPY ../../ .

# VERSION/GIT_COMMIT/BUILD_TIME are passed in to inject version metadata via ldflags.
# Empty defaults let the Makefile fall back to its own git/date detection when callers
# don't supply explicit values; ${VAR:+...} forwards only when the caller set them.
ARG VERSION=dev
ARG GIT_COMMIT=
ARG BUILD_TIME=
RUN make machina-build VERSION=${VERSION} ${GIT_COMMIT:+GIT_COMMIT=${GIT_COMMIT}} ${BUILD_TIME:+BUILD_TIME=${BUILD_TIME}}

# Runtime stage
FROM mcr.microsoft.com/azurelinux/base/core:3.0@sha256:35149ae8dd179684f969944f54a337c665a64e702486154eb44253fb39c2505b

# Install runtime dependencies
RUN tdnf install -y \
    ca-certificates \
    && tdnf clean all

# Create unbounded directory
RUN mkdir -p /unbounded/bin

# Copy the built binaries from the builder stage
COPY --from=builder /src/bin/machina /unbounded/bin/machina

# Add unbounded bin to PATH
ENV PATH="/unbounded/bin:${PATH}"

# Set working directory
WORKDIR /unbounded

# Default entrypoint
ENTRYPOINT ["/unbounded/bin/machina"]
